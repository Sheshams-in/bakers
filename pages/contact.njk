<!-- CONTACT SECTION -->
<section class="contact_section layout_padding">
  <div class="container">
    <div class="heading_container heading_center">
      <h2>Contact Us</h2>
    </div>

    <div class="row" style="margin-top: 2rem;">
      <div class="col-md-6">
        <h3 style="margin-bottom: 1.5rem;">Send us a Message</h3>
        <form class="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
        <div class="form-group">
          <label for="name" class="form-label">Name *</label>
          <input type="text" id="name" name="name" required class="form-input" placeholder="Your name">
        </div>

        <div class="form-group">
          <label for="email" class="form-label">Email *</label>
          <input type="email" id="email" name="email" required class="form-input" placeholder="your@email.com">
        </div>

        <div class="form-group">
          <label for="phone" class="form-label">Phone (optional)</label>
          <input type="tel" id="phone" name="phone" class="form-input" placeholder="+1 (555) 000-0000">
        </div>

        <div class="form-group">
          <label for="message" class="form-label">Message *</label>
          <textarea id="message" name="message" required class="form-textarea" placeholder="Tell us about your cake vision..." rows="6"></textarea>
        </div>

        <button type="submit" class="btn btn--primary">Send Inquiry</button>
      </form>
      </div>

      <div class="col-md-6">
        <h3 style="margin-bottom: 1.5rem;">Connect With Us</h3>
        <div class="row">
          <!-- WhatsApp -->
          <div class="col-12 mb-4">
            <div class="box" style="text-align: center;">
              <div class="img-box" style="background: linear-gradient(135deg, #25D366 0%, #20BA58 100%); height: 150px; display: flex; align-items: center; justify-content: center; border-radius: 8px; margin-bottom: 1rem;">
                <i class="fa fa-whatsapp" style="font-size: 3rem; color: white;"></i>
              </div>
              <div class="detail-box">
                <h5>WhatsApp Chat</h5>
                <p>Quick messages and quick replies</p>
                <a href="https://wa.me/?text=Hi%20Sheshams%20Bakers!%20I%27m%20interested%20in%20ordering%20a%20custom%20cake" class="btn btn-primary" target="_blank" style="background-color: #25D366; border-color: #25D366;">Chat Now</a>
              </div>
            </div>
          </div>

          <!-- Instagram -->
          <div class="col-12 mb-4">
            <div class="box" style="text-align: center;">
              <div class="img-box" style="background: linear-gradient(135deg, #E1306C 0%, #C13584 100%); height: 150px; display: flex; align-items: center; justify-content: center; border-radius: 8px; margin-bottom: 1rem;">
                <i class="fa fa-instagram" style="font-size: 3rem; color: white;"></i>
              </div>
              <div class="detail-box">
                <h5>Instagram</h5>
                <p>See our latest creations and DM us</p>
                <a href="https://www.instagram.com/sheshams_bakers/" class="btn btn-primary" target="_blank" style="background-color: #E1306C; border-color: #E1306C;">Follow Us</a>
              </div>
            </div>
          </div>

          <!-- Phone -->
          <div class="col-12">
            <div class="box" style="text-align: center;">
              <div class="img-box" style="background: linear-gradient(135deg, #007BFF 0%, #0056B3 100%); height: 150px; display: flex; align-items: center; justify-content: center; border-radius: 8px; margin-bottom: 1rem;">
                <i class="fa fa-phone" style="font-size: 3rem; color: white;"></i>
              </div>
              <div class="detail-box">
                <h5>Call Us</h5>
                <p>+91-9876543210</p>
                <p style="font-size: 0.9rem; color: #666;">Mon - Sun, 9 AM - 10 PM</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
