<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or 'Premium artisan cakes, cupcakes, and specialty desserts. Vegetarian & Eggless. Order custom cakes via WhatsApp.' }}">
  <meta property="og:title" content="{{ title or 'Sheshams Bakers - Premium Artisan Cakes' }}">
  <meta property="og:description" content="{{ description or 'Handcrafted vegetarian cakes & cupcakes. 100% eggless. Custom designs available.' }}">
  <meta property="og:image" content="{{ ogImage or '/assets/images/og-image.jpg' }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ url or 'https://sheshams-bakers.com' }}">
  <meta name="theme-color" content="#0066cc">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  
  <title>{{ title or 'Sheshams Bakers' }}</title>
  
  <!-- Bootstrap 4 CSS (Feane) -->
  <link rel="stylesheet" type="text/css" href="/assets/css/bootstrap.css">
  
  <!-- Font Awesome for icons (Feane) -->
  <link href="/assets/css/font-awesome.min.css" rel="stylesheet" />
  
  <!-- Bootstrap Icons (Free & Open Source) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  
  <!-- jQuery Nice Select -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-nice-select/1.1.0/css/nice-select.min.css" integrity="sha512-CruCP+TD3yXzlvvijET8wV5WxxEh5H8P4cmz0RFbKK6FlZ2sYl3AEsKlLPHbniXKSrDdFewhbmBK5skbdsASbQ==" crossorigin="anonymous">
  
  <!-- Owl Carousel CSS -->
  <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css" />
  
  <!-- Sheshams Bakers Custom CSS (Feane Template) -->
  <link href="/assets/css/style.css" rel="stylesheet" />
  <!-- responsive style -->
  <link href="/assets/css/responsive.css" rel="stylesheet" />
  <link rel="icon" href="/assets/images/favicon.ico">
  
  <!-- AOS (Animate On Scroll) Library for smooth scroll animations -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" />
</head>
<body>
  {% include "header.njk" %}
  
  <main>
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}
  
  <!-- jQuery 3.4.1 (Feane) -->
  <script src="/assets/js/jquery-3.4.1.min.js"></script>
  <!-- popper js -->
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js" integrity="sha384-Q6E9RHvbIyZFJoft+2mJbHaEWldlvI9IOYy5n3zV9zzTtmI3UksdQRVvoxMfooAo" crossorigin="anonymous"></script>
  <!-- bootstrap js (Feane) -->
  <script src="/assets/js/bootstrap.js"></script>
  <!-- owl slider -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>
  <!-- isotope js -->
  <script src="https://unpkg.com/isotope-layout@3.0.4/dist/isotope.pkgd.min.js"></script>
  <!-- nice select -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-nice-select/1.1.0/js/jquery.nice-select.min.js"></script>
  <!-- custom js (Feane) -->
  <script src="/assets/js/custom.js"></script>
  <!-- Main JS -->
  <script src="/assets/js/main.js"></script>
  <!-- Menu Search JS (for menu page) -->
  <script src="/assets/js/menu-search.js"></script>
</body>
</html>

