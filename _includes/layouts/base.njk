<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or 'Premium artisan cakes, cupcakes, and specialty desserts. Vegetarian & Eggless. Order custom cakes via WhatsApp.' }}">
  <meta property="og:title" content="{{ title or 'Sheshams Bakers - Premium Artisan Cakes' }}">
  <meta property="og:description" content="{{ description or 'Handcrafted vegetarian cakes & cupcakes. 100% eggless. Custom designs available.' }}">
  <meta property="og:image" content="{{ ogImage or '/assets/images/og-image.jpg' | url }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ url or 'https://sheshams-bakers.com' }}">
  <meta name="theme-color" content="#0066cc">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  
  {% if googleVerification %}
  <meta name="google-site-verification" content="{{ googleVerification }}" />
  {% endif %}
  
  <title>{{ title or 'Sheshams Bakers' }}</title>
  
  <!-- Base path meta tag (set during build from ELEVENTY_PATH_PREFIX env var) -->
  <meta name="baseline-path" content="{{ basePath or '/' }}">
  
  <!-- Bootstrap 4 CSS -->
  <link rel="stylesheet" type="text/css" href="{{ '/assets/css/bootstrap.css' | url }}">
  
  <!-- Font Awesome 6.x for icons (CDN - jsDelivr) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css">
  
  <!-- Bootstrap Icons (Free & Open Source) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  
  <!-- jQuery Nice Select -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-nice-select/1.1.0/css/nice-select.min.css" integrity="sha512-CruCP+TD3yXzlvvijET8wV5WxxEh5H8P4cmz0RFbKK6FlZ2sYl3AEsKlLPHbniXKSrDdFewhbmBK5skbdsASbQ==" crossorigin="anonymous">
  
  <!-- Owl Carousel CSS -->
  <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css" />
  
  <!-- Sheshams Bakers Custom CSS -->
  <link href="{{ '/assets/css/style.css' | url }}" rel="stylesheet" />
  <!-- Responsive styles -->
  <link href="{{ '/assets/css/responsive.css' | url }}" rel="stylesheet" />
  
  <!-- Theme Stylesheet (Gold or Purple) - change href to switch themes -->
  <link id="theme-stylesheet" rel="stylesheet" href="{{ '/assets/css/theme-gold.css' | url }}">
  
  <link rel="icon" type="image/png" href="{{ '/assets/images/Logo/Logo_200x200.png' | url }}">
  
  <!-- AOS (Animate On Scroll) Library for smooth scroll animations -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" />

  <!-- Local Business Schema Markup for Google Local Search -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Sheshams Bakers",
    "image": "https://bakers.sheshams.in/assets/images/og-image.jpg",
    "description": "Premium artisan cakes, cupcakes, and specialty desserts. 100% Vegetarian & Eggless. Custom cakes in Baltimore, Maryland.",
    "url": "https://bakers.sheshams.in",
    "telephone": "+1-858-264-6374",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Owings Mills",
      "addressLocality": "Owings Mills",
      "addressRegion": "MD",
      "postalCode": "21117",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "39.4699",
      "longitude": "-76.7875"
    },
    "areaServed": {
      "@type": "State",
      "name": "Maryland"
    },
    "priceRange": "$$",
    "serviceType": "Custom Cakes, Cupcakes, Desserts",
    "sameAs": [
      "https://www.instagram.com/sheshams_bakers"
    ]
  }
  </script>

</head>
<body>
  <!-- Global base path for dynamic asset loading -->
  <script>
    /**
     * Read basePath from meta tag (set during build from ELEVENTY_PATH_PREFIX)
     * Falls back to intelligent detection for custom domains vs GitHub Pages
     * Always removes trailing slashes to prevent double slashes in URLs
     */
    (function() {
      // Try to read from meta tag first
      const metaTag = document.querySelector('meta[name="baseline-path"]');
      if (metaTag) {
        let basePath = metaTag.getAttribute('content');
        // Remove trailing slash to avoid double slashes
        basePath = basePath.replace(/\/$/, '');
        window.basePath = basePath;
        console.log('✓ Base path from meta tag:', window.basePath || '(root)');
        return;
      }
      
      // Fallback: Intelligent detection based on hostname
      const hostname = window.location.hostname;
      const pathname = window.location.pathname;
      
      // Custom domains (sheshams.in, bakers.sheshams.in) → root path
      if (hostname.includes('sheshams') || hostname.includes('bakers')) {
        window.basePath = '';
        console.log('✓ Custom domain detected, base path: (root)');
      } else {
        // GitHub Pages → detect repo name from pathname
        const segments = pathname.split('/').filter(Boolean);
        window.basePath = segments.length > 0 ? '/' + segments[0] : '';
        console.log('✓ GitHub Pages detected, base path:', window.basePath || '(root)');
      }
    })();
  </script>

  <!-- Font Loader (must come after basePath is set) -->
  <script src="{{ '/assets/js/font-loader.js' | url }}"></script>

  {% include "header.njk" %}
  
  <main>
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}
  
  <!-- jQuery 3.4.1 -->
  <script src="{{ '/assets/js/jquery-3.4.1.min.js' | url }}"></script>
  <!-- Popper JS -->
  <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js" integrity="sha384-Q6E9RHvbIyZFJoft+2mJbHaEWldlvI9IOYy5n3zV9zzTtmI3UksdQRVvoxMfooAo" crossorigin="anonymous"></script>
  <!-- Bootstrap JS -->
  <script src="{{ '/assets/js/bootstrap.js' | url }}"></script>
  <!-- Owl Carousel -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>
  <!-- Isotope JS -->
  <script src="https://unpkg.com/isotope-layout@3.0.4/dist/isotope.pkgd.min.js"></script>
  <!-- Nice Select -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-nice-select/1.1.0/js/jquery.nice-select.min.js"></script>
  <!-- Custom JS -->
  <script src="{{ '/assets/js/custom.js' | url }}"></script>
  <!-- Main JS -->
  <script src="{{ '/assets/js/main.js' | url }}"></script>
  <!-- Carousel Initialization (loads after jQuery) -->
  <script src="{{ '/assets/js/carousel-init.js' | url }}"></script>
  <!-- Menu Initialization (loads after jQuery & Isotope) -->
  <script src="{{ '/assets/js/menu-init.js' | url }}"></script>
  
  <!-- Theme Switcher JS -->
  <script src="{{ '/assets/js/theme-switcher.js' | url }}"></script>
</body>
</html>

