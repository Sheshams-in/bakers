<!-- ============================================
     MENU HERO (sub-page minimal header)
     ============================================ -->
<section class="hero_area sub_page_hero">
  <div class="bg-box">
    <img src="/assets/images/hero-bg.jpg" alt="Sheshams Bakers Menu">
  </div>
  <div class="slider_section">
    <div class="detail-box">
      <h1>Our Menu</h1>
      <p style="color: rgba(255,255,255,0.85);">Handcrafted creations — 100% Vegetarian &amp; Eggless</p>
    </div>
  </div>
</section>

<!-- ============================================
     MENU SECTION (Using Instagram Feed)
     ============================================ -->
<section class="food_section layout_padding" style="background: #f9f9f9;">
  <div class="container">

    <div class="heading_container heading_center" style="margin-bottom: 2rem;">
      <h2>Browse All Creations</h2>
      <p style="font-size: 1.1rem; color: #999; margin-top: 0.5rem;">Filter by category to explore our portfolio</p>
    </div>

    <!-- Category Filters -->
    <ul class="filters_menu">
      <li class="active" data-filter="*">All</li>
      <li data-filter=".birthday">Birthday</li>
      <li data-filter=".cupcakes">Cupcakes</li>
      <li data-filter=".tresletches">Tresletches</li>
      <li data-filter=".fondant">Fondant</li>
      <li data-filter=".speciality">Speciality</li>
      <li data-filter=".whipped-cream">Whipped Cream</li>
      <li data-filter=".butter-cream">Butter Cream</li>
    </ul>

    <!-- Menu Grid with Instagram Feed -->
    <div class="filters-content">
      <div class="row grid" id="menuGrid">
        <!-- Will be populated with Instagram feed -->
      </div>
    </div>

  </div>
</section>

<!-- Menu JavaScript to load Instagram feed -->
<script>
document.addEventListener('DOMContentLoaded', async function() {
  const menuGrid = document.getElementById('menuGrid');
  
  try {
    // Load Instagram feed data
    const response = await fetch('/posts/instagram-feed.json');
    if (!response.ok) {
      throw new Error('Failed to load posts');
    }
    
    const posts = await response.json();
    
    // Render posts
    posts.forEach(post => {
      const categories = (post.categories || []).map(cat => cat.toLowerCase().replace(/\s+/g, '-')).join(' ');
      
      const col = document.createElement('div');
      col.className = `col-sm-6 col-lg-4 all ${categories}`;
      
      col.innerHTML = `
        <div class="box">
          <div class="img-box">
            <img src="${post.localImagePath || post.imageUrl || '/assets/images/placeholder.jpg'}" alt="${post.caption || 'Sheshams Bakers cake'}" loading="lazy">
          </div>
          <div class="detail-box">
            <h5>${(post.categories && post.categories[0]) || 'Our Creation'}</h5>
            <p>${(post.caption || 'Beautiful handcrafted cake').substring(0, 80)}...</p>
          </div>
          <div class="box-footer">
            <a href="${post.permalink}" target="_blank" class="instagram-btn">
              <i class="fa-brands fa-instagram"></i>
              <span>View more</span>
            </a>
          </div>
        </div>
      `;
      
      menuGrid.appendChild(col);
    });
    
    // Initialize Isotope filtering
    const $grid = jQuery('.grid');
    $grid.isotope({
      itemSelector: '.col-sm-6',
      layoutMode: 'fitRows'
    });
    
    // Trigger layout after items load
    setTimeout(() => {
      $grid.isotope('layout');
    }, 100);
    
    // Filter functionality
    jQuery('.filters_menu li').on('click', function() {
      const filterValue = jQuery(this).attr('data-filter');
      jQuery('.filters_menu li').removeClass('active');
      jQuery(this).addClass('active');
      $grid.isotope({ filter: filterValue });
      
      // Re-layout after filtering
      setTimeout(() => {
        $grid.isotope('layout');
      }, 300);
    });
    
  } catch (error) {
    console.error('Error loading menu:', error);
    menuGrid.innerHTML = '<p style="text-align:center; grid-column: 1/-1;">Unable to load menu. Please try again later.</p>';
  }
});
</script>
